rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isValidContact() {
      return request.resource.data.keys().hasOnly(['name', 'email', 'message', 'createdAt', 'status'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        && request.resource.data.email.size() <= 180
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 1
        && request.resource.data.message.size() <= 4000
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time;
    }

    // Les projets sont lisibles par tous
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Les messages de contact peuvent être créés par tous
    match /contacts/{contactId} {
      allow create: if isValidContact();
      allow read, update, delete: if isAdmin();
    }
    
    // Par défaut, tout le reste est bloqué
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
