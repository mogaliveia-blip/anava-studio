rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Les images des projets sont lisibles par tous
    match /projects/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Par défaut, accès restreint
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
