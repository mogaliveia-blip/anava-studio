rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isProjectImage() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Les images des projets sont lisibles par tous
    match /projects/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isProjectImage();
    }
    
    // Par défaut, accès restreint mais lecture publique pour les assets
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
